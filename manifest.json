{
  "manifest_version": 3,
  "name": "InstaPoll Alert",
  "version": "1.0.0",
  "description": "Get notified instantly when a new UT Instapoll goes live — even if the tab is in the background.",
  "permissions": [
    "notifications",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "*://polls.la.utexas.edu/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://polls.la.utexas.edu/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
